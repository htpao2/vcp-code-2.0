{
	"name": "@nova-code/jetbrains-plugin",
	"license": "Apache-2.0",
	"type": "module",
	"devDependencies": {
		"del-cli": "^5.1.0",
		"cpy-cli": "^5.0.0",
		"mkdirp": "^3.0.1"
	},
	"scripts": {
		"clean": "node scripts/run-gradle.cjs clean",
		"build": "node scripts/run-gradle.cjs buildPlugin -PdebugMode=idea",
		"run": "node scripts/run-gradle.cjs runIde -PdebugMode=idea",
		"run:bundle": "node scripts/run-gradle.cjs runIde -PdebugMode=release",
		"bundle": "node scripts/run-gradle.cjs buildPlugin -PdebugMode=release",
		"bundle:name": "node scripts/get_bundle_name.js",
		"clean:novacode": "npx del-cli ./plugins/novacode --force && npx mkdirp ./plugins/novacode",
		"copy:novacode": "node -e \"require('fs').cpSync('../../bin-unpacked/extension', './plugins/novacode/extension', { recursive: true, force: true })\"",
		"clean:resource-novacode": "npx del-cli ../resources/novacode --force",
		"copy:resource-novacode": "node -e \"require('fs').cpSync('../../bin-unpacked/extension', '../resources/novacode', { recursive: true, force: true })\"",
		"clean:resource-host": "npx del-cli ../resources/runtime --force",
		"copy:resource-host": "node -e \"require('fs').cpSync('../host/dist', '../resources/runtime', { recursive: true, force: true })\"",
		"clean:resource-logs": "npx del-cli ../resources/logs --force",
		"copy:resource-logs": "npx mkdirp ../resources/logs",
		"clean:resource-nodemodules": "npx del-cli ../resources/node_modules --force && npx del-cli ../resources/package.json --force",
		"copy:resource-nodemodules": "node -e \"require('fs').copyFileSync('../host/package.json', '../resources/package.json')\" && npm install --prefix ../resources",
		"propDep": "npx del-cli ./propDep.txt --force && npm ls --omit=dev --all --parseable --prefix ../resources > ./prodDep.txt",
		"sync:version": "node scripts/sync_version.js",
		"sync:changelog": "node scripts/update_change_notes.js"
	}
}
